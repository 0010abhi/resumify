# Copy this to .env.local and fill in your values
# These are safe to expose (Supabase anon key is public by design)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-publishable-key>

# Set to "true" to route AI calls through Supabase Edge Functions
# Set to "false" (or omit) to call Gemini directly from the browser (dev fallback)
VITE_USE_BACKEND=true

# Only needed when VITE_USE_BACKEND=false
# VITE_GOOGLE_AI_API_KEY=<your-gemini-key>
